<div class="feature-highlights-container" id="feature-highlights-{{ block.id }}">
  <div class="feature-highlights-loader" style="text-align: center; padding: 50px;">Loading features...</div>
  <div class="feature-highlights-content" style="display: none;"></div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const containerId = "feature-highlights-{{ block.id }}";
  const container = document.getElementById(containerId);
  
  // Fetch section data directly from the app backend
  const appUrl = "https://highlight-pro-alpha.vercel.app";
  const shopDomain = "{{ shop.permanent_domain }}";
  fetch(`${appUrl}/api/storefront/section?shop=${encodeURIComponent(shopDomain)}`)
    .then(async response => {
      if (!response.ok) {
        const text = await response.text();
        throw new Error(`HTTP ${response.status}: ${text}`);
      }
      return response.json();
    })
    .then(data => {
      if (data.error) {
        container.innerHTML = "<p>Error loading section: " + data.error + "</p>";
        return;
      }
      
      const section = data.section;
      const settings = JSON.parse(section.settings);
      const contentDiv = container.querySelector(".feature-highlights-content");
      const loaderDiv = container.querySelector(".feature-highlights-loader");
      
      // Theme Editor overrides
      const themeSettings = {
        title: {{ block.settings.section_title | json }},
        subtitle: {{ block.settings.section_subtitle | json }},
        bgColor: {{ block.settings.bg_color | json }},
        textColor: {{ block.settings.text_color | json }},
        iconColor: {{ block.settings.icon_color | json }},
        padding: {{ block.settings.padding | json }},
        borderRadius: {{ block.settings.border_radius | json }},
        features: [
          { icon: {{ block.settings.feature_1_icon | json }}, title: {{ block.settings.feature_1_title | json }}, description: {{ block.settings.feature_1_description | json }} },
          { icon: {{ block.settings.feature_2_icon | json }}, title: {{ block.settings.feature_2_title | json }}, description: {{ block.settings.feature_2_description | json }} },
          { icon: {{ block.settings.feature_3_icon | json }}, title: {{ block.settings.feature_3_title | json }}, description: {{ block.settings.feature_3_description | json }} },
          { icon: {{ block.settings.feature_4_icon | json }}, title: {{ block.settings.feature_4_title | json }}, description: {{ block.settings.feature_4_description | json }} }
        ],
        buttonText: {{ block.settings.button_text | json }},
        buttonLink: {{ block.settings.button_link | json }},
        animations: {{ block.settings.animations | json }},
        templateSpecific: {{ block.settings.template_specific | json }}
      };

      if (themeSettings.title) section.title = themeSettings.title;
      if (themeSettings.subtitle) section.subtitle = themeSettings.subtitle;
      if (themeSettings.bgColor && themeSettings.bgColor !== "transparent" && themeSettings.bgColor !== "rgba(0,0,0,0)") settings.bgColor = themeSettings.bgColor;
      if (themeSettings.textColor && themeSettings.textColor !== "transparent" && themeSettings.textColor !== "rgba(0,0,0,0)") settings.textColor = themeSettings.textColor;
      if (themeSettings.iconColor && themeSettings.iconColor !== "transparent" && themeSettings.iconColor !== "rgba(0,0,0,0)") settings.iconColor = themeSettings.iconColor;
      if (themeSettings.padding) settings.padding = themeSettings.padding;
      if (themeSettings.borderRadius) settings.borderRadius = themeSettings.borderRadius;

      themeSettings.features.forEach((tf, index) => {
        if (section.features[index]) {
          if (tf.icon) section.features[index].icon = tf.icon;
          if (tf.title) section.features[index].title = tf.title;
          if (tf.description) section.features[index].description = tf.description;
        } else if (tf.title) {
          section.features.push({
            icon: tf.icon || "✨",
            title: tf.title,
            description: tf.description || ""
          });
        }
      });

      // Build HTML based on templateId
      let html = `<div style="background-color: ${settings.bgColor}; color: ${settings.textColor}; padding: ${settings.padding}; border-radius: ${settings.borderRadius}; ${themeSettings.animations ? 'animation: ' + themeSettings.animations + ';' : ''} ${themeSettings.templateSpecific ? themeSettings.templateSpecific : ''}">`;
      html += `<div style="text-align: center; margin-bottom: 30px;">`;
      html += `<h2 style="font-size: 2em; margin-bottom: 10px; color: ${settings.textColor};">${section.title}</h2>`;
      if (section.subtitle) html += `<p style="opacity: 0.8; color: ${settings.textColor};">${section.subtitle}</p>`;
      html += `</div>`;
      
      html += `<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">`;
      
      section.features.forEach(f => {
        // Simple generic design for all templates to start. In a real scenario, this switch handles 1-7.
        html += `<div style="padding: 20px; background: rgba(0,0,0,0.03); border-radius: ${settings.borderRadius}; text-align: center;">`;
        html += `<div style="font-size: 40px; color: ${settings.iconColor}; margin-bottom: 15px;">${f.icon}</div>`;
        html += `<h3 style="font-size: 18px; margin-bottom: 10px; color: ${settings.textColor};">${f.title}</h3>`;
        html += `<p style="opacity: 0.8; color: ${settings.textColor};">${f.description}</p>`;
        html += `</div>`;
      });
      
      html += `</div>`;

      if (themeSettings.buttonText && themeSettings.buttonLink) {
        html += `<div style="text-align: center; margin-top: 30px;">`;
        html += `<a href="${themeSettings.buttonLink}" style="display: inline-block; padding: 12px 24px; background-color: ${settings.iconColor}; color: #fff; text-decoration: none; border-radius: ${settings.borderRadius}; font-weight: bold;">${themeSettings.buttonText}</a>`;
        html += `</div>`;
      }

      html += `</div>`;
      
      contentDiv.innerHTML = html;
      contentDiv.style.display = "block";
      loaderDiv.style.display = "none";
    })
    .catch(err => {
      container.innerHTML = `<p style="color:red; text-align:center; padding:20px;">Failed to load feature section.<br><small>${err.message}</small></p>`;
      console.error("Feature Highlights Fetch Error:", err);
    });
});
</script>

